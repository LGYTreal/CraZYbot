# ================================
#   CraZYbot Environment Config
# ================================

# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your Application (Client) ID
CLIENT_ID=your_client_id_here

# Your server ID (for testing slash commands instantly in one guild)
GUILD_ID=your_guild_id_here

# Groq API Key (free!) — get one at https://console.groq.com
# Used for the /roast command (powered by Llama 3 via Groq)
GROQ_API_KEY=your_groq_api_key_here

# Reddit API (for meme fetching — create app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
